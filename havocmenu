local function rebuildAI()
local char=LocalPlayer and LocalPlayer.Character
local myHRP=char and char:FindFirstChild("HumanoidRootPart")
local myPos=myHRP and myHRP.Position; if not myPos then AI_STATE.items={}; return end
local myX,myY,myZ=myPos.X,myPos.Y,myPos.Z
local distSqMax=AI_STATE.distMax^2; local raw={}
for _,e in ipairs(getCharacters()) do
local hrp=e.hrp
if hrp and hrp.Parent then
local rootPos=hrp.Position
local dx=myX-rootPos.X; local dy=myY-rootPos.Y; local dz=myZ-rootPos.Z
local distSq=dx*dx+dy*dy+dz*dz
if distSq<=distSqMax then
local d=sqrt(distSq)
local healthRatio,healthColor
if e.hp and e.maxhp and e.maxhp>0 then
healthRatio=clamp(e.hp/e.maxhp,0,1); healthColor=hpColor(healthRatio)
end
raw[#raw+1]={
kind="ai", part=hrp, name=e.model.Name,
distText=floor(d).."m",
healthRatio=healthRatio, healthColor=healthColor,
weapon=e.weapon, _distSq=distSq,
}
end
end
end
table.sort(raw,function(a,b) return a._distSq<b._distSq end)
local out={}
for _,v in ipairs(raw) do
if #out>=AIC.MAX_SLOTS then break end; out[#out+1]=v
end
AI_STATE.items=out
end
