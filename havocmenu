local function tierColor(name)
local tier = ITEM_TIER[name]
return (tier and TIER_COLORS[tier]) or Color3.fromRGB(255, 255, 255)
end
local itemColors = {}
for name in pairs(ITEM_TIER) do itemColors[name] = tierColor(name) end
local function isAmmo(name)
local n = name:lower()
return n:find("x18mm") or n:find("x19mm") or n:find("x39mm")
or n:find("x51mm") or n:find("x54mm") or n:find("x28mm")
or n:find("x42mm") or n:find("x30mm") or n:find("x45")
or n:find("x75mm") or n:find("gauge buckshot")
or n:find("%.338") or n:find("%.408") or n:find("%.45 acp")
or n:find("%.50 action") or n:find("4%.6x") or n:find("5%.45x")
or n:find("5%.56x") or n:find("5%.7x") or n:find("5%.8x")
or n:find("7%.62x") or n:find("9x39mm") or n:find("23x75mm")
or n:find("40x46mm")
end
local function isAttachment(name)
local n = name:lower()
return n:find("magazine") or n:find("%-round ")
or n:find("suppressor") or n:find("silencer")
or n:find("foregrip") or n:find("grip")
or n:find("riflescope") or n:find("scope")
or n:find("holographic") or n:find("reflex sight")
or n:find("flash hider") or n:find("muzzle brake")
or n:find("compensator") or n:find("laser")
or n:find("tactical device") or n:find("headlamp")
end
local tierLists = {
mythic={}; rare={}; uncommon={}; common={}; keys={};
usable={}; household={}; ammo={}; attachments={};
}
for name, tier in pairs(ITEM_TIER) do
if isAmmo(name) then
tierLists.ammo[#tierLists.ammo+1] = name
elseif isAttachment(name) then
tierLists.attachments[#tierLists.attachments+1] = name
elseif tier == "mythic" then
tierLists.mythic[#tierLists.mythic+1] = name
elseif tier == "rare" then
tierLists.rare[#tierLists.rare+1] = name
elseif tier == "uncommon" then
tierLists.uncommon[#tierLists.uncommon+1] = name
elseif tier == "common" then
tierLists.common[#tierLists.common+1] = name
elseif tier == "keys" then
tierLists.keys[#tierLists.keys+1] = name
elseif tier == "usable_item" or tier == "usable_item_inhaler" then
tierLists.usable[#tierLists.usable+1] = name
elseif tier == "common_households" then
tierLists.household[#tierLists.household+1] = name
end
end
for _, list in pairs(tierLists) do table.sort(list) end
